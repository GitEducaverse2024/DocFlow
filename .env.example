# DocFlow
DATABASE_PATH=/app/data/docflow.db
PROJECTS_PATH=/app/data/projects

# External services
OPENCLAW_URL=http://your-host:18789
N8N_WEBHOOK_URL=http://your-host:5678
N8N_PROCESS_WEBHOOK_PATH=/webhook/docflow-process
QDRANT_URL=http://your-host:6333
LITELLM_URL=http://your-host:4000
LITELLM_API_KEY=your-litellm-api-key

# Ollama for local embeddings
OLLAMA_URL=http://docflow-ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# Chat model (must match a model configured in LiteLLM)
CHAT_MODEL=gemini-main

# OpenClaw agents (fallback if API doesn't return them)
OPENCLAW_AGENTS=[]

# OpenClaw workspace path for auto-creating bots
OPENCLAW_WORKSPACE_PATH=/home/youruser/.openclaw
